<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <application
        android:name=".AyikApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AYIK"
        android:localeConfig="@xml/locales_config">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AYIK"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Widget Config Activity -->
        <activity
            android:name=".widget.WidgetConfigActivity"
            android:exported="false"
            android:theme="@style/Theme.AYIK">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!-- Heatmap Small Widget (3x2) -->
        <receiver
            android:name=".widget.HeatmapSmallWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_heatmap_small">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_heatmap_small_info" />
        </receiver>

        <!-- Heatmap Medium Widget (4x2) -->
        <receiver
            android:name=".widget.HeatmapMediumWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_heatmap_medium">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_heatmap_medium_info" />
        </receiver>

        <!-- Heatmap Large Widget (5x3) -->
        <receiver
            android:name=".widget.HeatmapLargeWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_heatmap_large">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_heatmap_large_info" />
        </receiver>

        <!-- Alarm Receiver for Widget Updates -->
        <receiver
            android:name=".widget.WidgetAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="io.github.furkansariboga.ayik.FORCE_WIDGET_UPDATE" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
